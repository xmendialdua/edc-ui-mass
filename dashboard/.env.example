# EDC Dashboard - Configuración
# Copia este archivo a .env y ajusta los valores según tu entorno

# Ubicación del archivo kubeconfig (opcional, si no se proporciona busca en ubicaciones estándar)
# KUBECONFIG=/ruta/a/tu/kubeconfig.yaml

# Configuración del conector MASS
MASS_API=https://edc-mass-control.51.178.94.25.nip.io/management
MASS_API_KEY=mass-api-key-change-in-production
MASS_BPN=BPNL00000000MASS

# Configuración del conector IKLN
IKLN_API=https://edc-ikln-control.51.178.94.25.nip.io/management
IKLN_API_KEY=ikln-api-key-change-in-production
IKLN_BPN=BPNL00000002IKLN

# Puerto del backend (opcional, por defecto 5000)
# BACKEND_PORT=5000

# Puerto del frontend (opcional, por defecto 8083)
# FRONTEND_PORT=8083
